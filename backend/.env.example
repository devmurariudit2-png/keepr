# ── Backend Environment Variables (copy to Railway service vars) ──────────
# Required
DATABASE_URL=postgresql://user:password@host:5432/keepr
JWT_SECRET=replace_with_openssl_rand_hex_32
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — lock CORS to your Vercel domain in production
FRONTEND_URL=https://keepr.vercel.app

# Optional
ACCESS_TOKEN_EXPIRE_MINUTES=60
